{
  "name": "playwright-practice",
  "version": "1.0.0",
  "description": "Personal Playwright E2E test automation project by MC307.",
  "main": "index.js",
  "scripts": {
    "start:bagel": "cd bagel-shop && npm run start",
    "install:bagel-shop": "cd bagel-shop && npm install",
    "test": "npx playwright test",
    "test:chromium": "npx playwright test --project chromium",
    "test:first": "npx playwright test --grep @first",
    "test:local": "BASE_URL=http://localhost:4200 npx playwright test",
    "test:report": "npx playwright test && npx playwright show-report",
    "test:ui": "npx playwright test --ui",
    "test:codegen": "npx playwright codegen",
    "test:update-screenshots": "npx playwright test --update-snapshots"
  },
  "keywords": [],
  "author": "MC307",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@types/node": "^22.7.4",
    "dotenv": "^17.3.1"
  }
}
